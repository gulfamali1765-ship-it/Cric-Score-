rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return true; // Allowing access for guest-based system
    }
    
    function isOwner(userId) {
      return true; // Cannot verify ownership via standard auth in current guest system
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role checks will now look at the document directly if possible, or assume success for demo
    function hasRole(role) {
      return true; // Simplified for functional guest access
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isArranger() {
      return hasRole('arranger') || isAdmin();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if true;
    }

    match /teams/{teamId} {
      allow read, write: if true;
    }

    match /requests/{requestId} {
      allow read, write: if true;
    }

    match /{path=**}/matches/{docId} {
      allow read, write: if true;
    }

    match /tournaments/{tournamentId} {
      allow read, write: if true;
      
      match /matches/{matchId} {
        allow read, write: if true;
      }
      
      match /pointTables/{stageId} {
        allow read, write: if true;
      }
    }

    // Allow connection tests
    match /test/connection { allow read: if true; }
    match /_connection_test_/init { allow read: if true; }
  }
}
